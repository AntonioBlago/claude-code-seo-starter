{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/seo-check.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__visiblyai__list_projects",
      "mcp__visiblyai__get_google_connections",
      "mcp__visiblyai__query_search_console",
      "mcp__visiblyai__query_analytics",
      "mcp__visiblyai__get_keywords",
      "mcp__visiblyai__get_backlinks",
      "mcp__visiblyai__get_competitors",
      "mcp__visiblyai__get_referring_domains",
      "mcp__visiblyai__onpage_analysis",
      "mcp__visiblyai__analyze_url_structure",
      "mcp__visiblyai__check_links"
    ],
    "ask": [
      "mcp__visiblyai__crawl_website"
    ]
  }
}
