# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — your keys never leave your machine.

# --- Visibly AI MCP ---------------------------------------------------------
# Get your key from https://visibly-ai.com (Account → API). Keys look like `lc_...`.
VISIBLY_AI_API_KEY=lc_replace_me

# Optional: pin a default project / workspace if your account has several.
# VISIBLY_AI_PROJECT=

# --- Optional extra data sources (uncomment if you add them to .mcp.json) ---
# GA4_PROPERTY_ID=
# AHREFS_API_KEY=
